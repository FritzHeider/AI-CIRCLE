# ======================
# AgentHub Configuration
# ======================

# Server
AGENTHUB_HOST=0.0.0.0
AGENTHUB_PORT=8000
AGENTHUB_ENV=development

# Redis
REDIS_URL=redis://redis:6379

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...
FALAI_API_KEY=...

# Cost Defaults
DEFAULT_SESSION_BUDGET_CENTS=500
DEFAULT_AGENT_RATE_LIMIT_TPM=100000
DEFAULT_AGENT_COST_LIMIT_CENTS_PER_HOUR=100

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
